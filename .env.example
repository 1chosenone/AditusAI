# Database
DATABASE_URL=sqlite:///candidate.db

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=DEBUG

# LLM (supports any litellm provider: openai, anthropic, etc.)
ANTHROPIC_API_KEY=your_api_key_here
OPENAI_API_KEY=your_api_key_here
# etc...

# Format: provider/model (e.g., anthropic/claude-3-haiku-20240229, openai/gpt-4)
LLM_MODEL_NAME=anthropic/claude-haiku-4-5-20251001
